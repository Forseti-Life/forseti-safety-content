{#
/**
 * @file
 * Template for Agent Power Framework dimension detail pages.
 *
 * Available variables:
 * - dimension_id: Machine name of the dimension (scope, restriction, etc.)
 * - dimension_name: Human-readable name
 * - dimension_description: Full description of the dimension
 * - levels: Array of level data (0-8), each containing:
 *   - level: Numeric level (0-8)
 *   - badge: Bootstrap badge class
 *   - label: Label text (e.g., "SCOPE 0")
 *   - name: Short name (e.g., "Omniscient")
 *   - title: Level title
 *   - description: Full description of this level
 * - back_link: URL to return to main hierarchy page
 */
#}
<div class="container py-3">
  <div class="row">
    <div class="col-lg-10 mx-auto">
      
      {# Breadcrumb navigation #}
      <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="link-cyan">{{ 'Home'|t }}</a></li>
          <li class="breadcrumb-item"><a href="{{ back_link }}" class="link-cyan">{{ 'Agent Power Framework'|t }}</a></li>
          <li class="breadcrumb-item active text-cyan" aria-current="page">{{ dimension_name }}</li>
        </ol>
      </nav>

      {# Page header #}
      <div class="text-center mb-4">
        <h1 class="mb-3 text-cyan">{{ dimension_name }}</h1>
        <p class="lead text-muted-light">{{ dimension_description }}</p>
      </div>

      {# Context note - Why this matters #}
      <div class="card card-forseti p-4 mb-4">
        <h3 class="text-cyan mb-3"><i class="fas fa-lightbulb"></i> {{ 'Why This Matters'|t }}</h3>
        <p class="text-muted-light mb-0">
          {{ 'Understanding where an AI system operates on this dimension helps you evaluate its capabilities, limitations, and potential biases. Different power levels are appropriate for different use cases - the key is transparency about what level a system operates at and whether that matches its stated purpose.'|t }}
        </p>
      </div>

      {# Level scale explanation #}
      <div class="alert alert-info-cyan mb-4">
        <h4 class="text-cyan mb-2"><i class="fas fa-info-circle"></i> {{ 'Understanding the Scale'|t }}</h4>
        <p class="mb-2">
          {{ 'Each dimension is measured on a scale from 0 to 9, where:'|t }}
        </p>
        <ul class="mb-0">
          <li><strong class="text-danger">{{ 'Level 0'|t }}</strong> - {{ 'Nothing: Zero capability, no access or processing'|t }}</li>
          <li><strong class="text-danger">{{ 'Levels 1-2'|t }}</strong> - {{ 'Minimal capability with extreme constraints and filtering'|t }}</li>
          <li><strong class="text-warning">{{ 'Levels 3-5'|t }}</strong> - {{ 'Limited to moderate capability with significant restrictions'|t }}</li>
          <li><strong class="text-info">{{ 'Levels 6-7'|t }}</strong> - {{ 'High capability with some institutional constraints'|t }}</li>
          <li><strong class="text-success">{{ 'Levels 8-9'|t }}</strong> - {{ 'Maximum capability approaching omniscience (∞)'|t }}</li>
        </ul>
      </div>

      {# Level breakdown #}
      <h2 class="mb-3 text-cyan">{{ 'Level Breakdown'|t }}</h2>
      <p class="text-muted-light mb-4">
        {{ 'Detailed explanation of each level in the %dimension dimension:'|t|format({'%dimension': dimension_name}) }}
      </p>

      {# Levels accordion #}
      <div class="accordion mb-5" id="levelsAccordion">
        {% for level_data in levels %}
          <div class="accordion-item card-forseti border-secondary mb-2">
            <h2 class="accordion-header" id="heading{{ level_data.level }}">
              <button class="accordion-button {{ loop.first ? '' : 'collapsed' }} card-forseti text-white d-flex align-items-center" 
                      type="button" 
                      data-bs-toggle="collapse" 
                      data-bs-target="#collapse{{ level_data.level }}" 
                      aria-expanded="{{ loop.first ? 'true' : 'false' }}" 
                      aria-controls="collapse{{ level_data.level }}">
                <span class="badge {{ level_data.badge }} me-3" style="min-width: 100px;">{{ level_data.label }}</span>
                <div>
                  <div class="fw-bold">{{ level_data.name }}</div>
                  <div class="small text-muted-light">{{ level_data.title }}</div>
                </div>
              </button>
            </h2>
            <div id="collapse{{ level_data.level }}" 
                 class="accordion-collapse collapse {{ loop.first ? 'show' : '' }}" 
                 aria-labelledby="heading{{ level_data.level }}" 
                 data-bs-parent="#levelsAccordion">
              <div class="accordion-body card-forseti">
                <p class="text-muted-light">{{ level_data.description }}</p>
                {% if level_data.example %}
                  <div class="alert alert-info-cyan mt-3 mb-0">
                    <strong><i class="fas fa-building"></i> {{ 'Real-World Example:'|t }}</strong> {{ level_data.example }}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {# Navigation back #}
      <div class="text-center mb-4">
        <a href="{{ back_link }}" class="btn btn-primary">
          <i class="fas fa-arrow-left"></i> {{ 'Return to Agent Power Framework'|t }}
        </a>
      </div>

    </div>
  </div>
</div>
