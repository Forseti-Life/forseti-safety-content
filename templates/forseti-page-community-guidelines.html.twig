{#
/**
 * @file
 * Template for Community Guidelines page.
 *
 * Available variables:
 * - title: Page title
 * - intro: Introduction text
 * - core_values: Array of core value items
 * - expected_behavior: Expected behavior section
 * - prohibited_behavior: Prohibited behavior section
 * - reporting_incidents: Reporting incidents section
 * - consequences: Consequences section
 * - reporting_violations: Reporting violations section
 */
#}
<div class="container py-3">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <h1 class="text-center mb-3 text-cyan">{{ title }}</h1>
      
      <p class="lead">{{ intro }}</p>
      
      <h2 class="mt-4 mb-3 text-cyan">{{ 'Core Values'|t }}</h2>
      
      <div class="row">
        {% for value in core_values %}
          <div class="col-md-6 mb-3">
            <div class="card card-forseti p-3 h-100">
              <h5>{{ value.icon|raw }} {{ value.title }}</h5>
              <p class="mb-0">{{ value.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <h2 class="mt-5 mb-3 text-cyan">{{ expected_behavior.title }}</h2>
      <ul>
        {% for item in expected_behavior.items %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      
      <div class="alert alert-danger mt-4">
        <h4>{{ prohibited_behavior.title }}</h4>
        <ul class="mb-0">
          {% for item in prohibited_behavior.items %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      
      <h2 class="mt-5 mb-3 text-cyan">{{ reporting_incidents.title }}</h2>
      
      <div class="row">
        <div class="col-md-6">
          <div class="card card-forseti p-3 h-100">
            <h5>{{ reporting_incidents.best_practices.title }}</h5>
            <ul>
              {% for item in reporting_incidents.best_practices.items %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card card-forseti p-3 h-100">
            <h5>{{ reporting_incidents.avoid.title }}</h5>
            <ul>
              {% for item in reporting_incidents.avoid.items %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
      
      <h2 class="mt-5 mb-3 text-cyan">{{ consequences.title }}</h2>
      
      {% for level in consequences.levels %}
        <div class="card card-forseti p-3 mb-3">
          <h5>{{ level.level }}</h5>
          <p class="mb-0"><strong>{{ 'Action:'|t }}</strong> {{ level.action }}</p>
        </div>
      {% endfor %}
      
      <p class="mt-3"><em>{{ consequences.appeal|raw }}</em></p>
      
      <div class="alert alert-info mt-5">
        <h4>{{ reporting_violations.title }}</h4>
        <p class="mb-0">{{ reporting_violations.content|raw }}</p>
      </div>
    </div>
  </div>
</div>
