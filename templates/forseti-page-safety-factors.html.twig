{#
/**
 * @file
 * Template for Safety Factors page.
 *
 * Available variables:
 * - title: Page title
 * - lead: Lead paragraph
 * - assessment_alert: Comprehensive assessment alert
 * - dimensions_title: Dimensions section title
 * - dimensions_intro: Intro text for dimensions
 * - dimensions: Array of safety dimension items
 * - how_forseti_uses: How Forseti uses framework section
 * - cta_buttons: Call-to-action buttons
 */
#}
<div class="container py-3">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <h1 class="text-center mb-3 text-cyan">{{ title }}</h1>
      
      <p class="lead mb-4 text-muted-light">{{ lead }}</p>
      
      <div class="alert alert-info-cyan mb-4">
        <h4 class="text-cyan">{{ assessment_alert.title }}</h4>
        <p class="mb-0">{{ assessment_alert.content }}</p>
      </div>
      
      <h2 class="mb-3 text-cyan">{{ dimensions_title }}</h2>
      <p class="text-muted-light mb-4">{{ dimensions_intro }}</p>
      
      <div class="accordion mb-4" id="safetyFactorsAccordion">
        {% for dimension in dimensions %}
          <div class="accordion-item card-forseti border-secondary mb-2">
            <h2 class="accordion-header" id="heading{{ dimension.id }}">
              <button class="accordion-button collapsed card-forseti text-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ dimension.id }}" aria-expanded="false" aria-controls="collapse{{ dimension.id }}">
                <img src="{{ dimension.icon }}" alt="{{ dimension.name }}" class="forseti-icon me-2">
                <strong>{{ dimension.name }}{% if dimension.planned_enhancement %} <span class="text-muted-gray">(Planned Enhancement)</span>{% endif %}</strong>
              </button>
            </h2>
            <div id="collapse{{ dimension.id }}" class="accordion-collapse collapse" aria-labelledby="heading{{ dimension.id }}" data-bs-parent="#safetyFactorsAccordion">
              <div class="accordion-body card-forseti">
                <h5 class="text-cyan mb-3">{{ dimension.subtitle }}</h5>
                <p class="text-muted-light mb-3">{{ dimension.description }}</p>
                {% if dimension.integration_note %}
                  <p class="text-muted-light mb-3">
                    {{ dimension.integration_note.message }}
                    {% if dimension.integration_note.link %}
                      <a href="{{ dimension.integration_note.link }}" class="text-cyan">{{ dimension.integration_note.link_text }}</a>
                    {% endif %}
                  </p>
                {% endif %}
                <h6 class="text-cyan mb-2">{{ 'Safety Factors:'|t }}</h6>
                <ul class="text-muted-light">
                  {% for factor in dimension.factors %}
                    <li>{{ factor }}</li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div class="card card-forseti p-4 mb-4">
        <h3 class="text-cyan mb-3">{{ how_forseti_uses.title }}</h3>
        <ul class="text-muted-light mb-0">
          {% for item in how_forseti_uses.items %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="text-center mb-4">
        {% for button in cta_buttons %}
          <a href="{{ button.url }}" class="btn btn-{{ button.style }}{% if not loop.first %} ms-2{% endif %}">{{ button.label }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
      </div>
    </div>
  </div>
</div>
