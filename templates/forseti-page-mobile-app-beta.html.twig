{#
/**
 * @file
 * Template for Mobile App Beta Testing page (authenticated users only).
 *
 * Available variables:
 * - title: Page title
 * - subtitle: Page subtitle
 * - download_section: Download information and button
 */
#}
<div class="container py-3">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <h1 class="text-center mb-2 text-cyan">{{ title }}</h1>
      <p class="text-center mb-4 text-muted-light">{{ subtitle }}</p>
      
      <div class="alert alert-info text-center mb-4">
        <p class="mb-0">
          <i class="fas fa-lock text-cyan"></i> 
          <strong>{{ 'Authenticated Users Only'|t }}</strong>
        </p>
      </div>
      
      <div class="alert alert-success text-center mb-4">
        <h3 class="text-success mb-3">{{ download_section.title|raw }}</h3>
        <p class="lead mb-4">{{ download_section.description }}</p>
        
        <a href="{{ download_section.download_url }}" 
           class="btn btn-success btn-lg mb-3" 
           download
           style="background-color: #28a745; border-color: #28a745;">
          {{ download_section.button_text|raw }}
        </a>
        
        <p class="text-muted mb-2">
          <small>{{ download_section.version_info|raw }}</small>
        </p>
        <p class="text-muted mb-0">
          <small>{{ download_section.availability }}</small>
        </p>
      </div>
      
      <div class="card card-forseti mb-4">
        <div class="card-body">
          <h4 class="text-cyan mb-3">
            <i class="fas fa-info-circle"></i> {{ 'Installation Instructions'|t }}
          </h4>
          
          <ol class="text-muted-light">
            <li class="mb-2">
              <strong>{{ 'Enable Unknown Sources:'|t }}</strong> 
              {{ 'Go to Settings → Security → Unknown Sources and enable installation from unknown sources.'|t }}
            </li>
            <li class="mb-2">
              <strong>{{ 'Download the APK:'|t }}</strong> 
              {{ 'Click the download button above to get the latest version.'|t }}
            </li>
            <li class="mb-2">
              <strong>{{ 'Install:'|t }}</strong> 
              {{ 'Open the downloaded APK file and follow the installation prompts.'|t }}
            </li>
            <li class="mb-2">
              <strong>{{ 'Provide Feedback:'|t }}</strong> 
              {{ 'Use the app and report any issues or suggestions through the Forseti chat.'|t }}
            </li>
          </ol>
        </div>
      </div>
      
      <div class="card card-forseti mb-4">
        <div class="card-body">
          <h4 class="text-cyan mb-3">
            <i class="fas fa-exclamation-triangle"></i> {{ 'Beta Testing Notes'|t }}
          </h4>
          
          <ul class="text-muted-light">
            <li class="mb-2">
              {{ 'This is a beta version - expect bugs and incomplete features.'|t }}
            </li>
            <li class="mb-2">
              {{ 'Your feedback is crucial for improving the app before full launch.'|t }}
            </li>
            <li class="mb-2">
              {{ 'Android 5.0 (Lollipop) or higher is required.'|t }}
            </li>
            <li class="mb-2">
              {{ 'The app requires approximately 18MB of storage space.'|t }}
            </li>
            <li>
              {{ 'iOS version is in development and will be available soon.'|t }}
            </li>
          </ul>
        </div>
      </div>
      
      <div class="text-center">
        <a href="/mobile-app" class="btn btn-outline-cyan">
          <i class="fas fa-arrow-left"></i> {{ 'Back to Mobile App Info'|t }}
        </a>
      </div>
    </div>
  </div>
</div>
